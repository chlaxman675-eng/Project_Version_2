# SurakshaNet AI — environment configuration

# --- Backend ---
ENVIRONMENT=development
JWT_SECRET=change-me-in-production
DATABASE_URL=sqlite+aiosqlite:///./surakshanet.db
SIMULATION_TICK_SECONDS=2.0
ENABLE_SIMULATION_ON_STARTUP=true
ENABLE_YOLO=false
DETECTION_CONFIDENCE_THRESHOLD=0.55
FUSION_ALERT_THRESHOLD=0.65

# --- Frontend (Vite) ---
VITE_API_BASE=/api
# VITE_WS_HOST=localhost:8000   # override if backend not on same host
